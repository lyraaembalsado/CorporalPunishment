<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PAUSE — Positive Discipline Flipbook</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --p: #3B2F7F;
    --p-light: #EEEDFE;
    --teal: #0F6E56;
    --teal-light: #E1F5EE;
    --amber: #854F0B;
    --amber-light: #FAEEDA;
    --coral: #993C1D;
    --coral-light: #FAECE7;
    --green: #3B6D11;
    --green-light: #EAF3DE;
    --ink: #1a1714;
    --ink2: #4a4742;
    --ink3: #8a8780;
    --surface: #faf9f7;
    --card: #ffffff;
    --border: rgba(0,0,0,0.09);
    --radius: 16px;
  }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--surface);
    color: var(--ink);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2rem 1rem 4rem;
  }

  h1, h2, h3 { font-family: 'DM Serif Display', serif; }

  .top-label {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink3);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .flipbook {
    width: 100%;
    max-width: 420px;
  }

  .page {
    display: none;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem 1.75rem 1.5rem;
    min-height: 560px;
    flex-direction: column;
    justify-content: space-between;
    box-shadow: 0 2px 12px rgba(0,0,0,0.04), 0 1px 3px rgba(0,0,0,0.06);
    animation: fadeIn 0.25s ease;
  }
  .page.active { display: flex; }

  @keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }

  .page-label {
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink3);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .progress-bar {
    height: 2px;
    background: var(--border);
    border-radius: 2px;
    margin-bottom: 2rem;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: var(--ink);
    border-radius: 2px;
    transition: width 0.4s ease;
  }

  .cover-title {
    font-size: 72px;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 0.25rem;
  }
  .cover-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink3);
    margin-bottom: 1.5rem;
  }
  .cover-hook {
    font-size: 17px;
    line-height: 1.6;
    color: var(--ink2);
    margin-bottom: 2rem;
  }
  .cover-desc {
    font-size: 13px;
    line-height: 1.7;
    color: var(--ink3);
  }

  .step-letter {
    font-size: 80px;
    line-height: 1;
    margin-bottom: 0.1rem;
    font-family: 'DM Serif Display', serif;
  }
  .step-word {
    font-size: 24px;
    font-weight: 300;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    color: var(--ink2);
  }
  .step-action {
    font-size: 15px;
    line-height: 1.65;
    color: var(--ink);
    margin-bottom: 1rem;
    font-weight: 400;
  }
  .step-why {
    font-size: 13px;
    line-height: 1.65;
    color: var(--ink2);
    padding: 0.875rem 1rem;
    border-left: 2px solid var(--border);
    margin-bottom: 1rem;
  }
  .scenario-box {
    background: var(--surface);
    border-radius: 10px;
    padding: 1rem 1.125rem;
    font-size: 13px;
    line-height: 1.65;
    color: var(--ink2);
  }
  .scenario-label {
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--ink3);
    margin-bottom: 0.5rem;
  }

  .reflection-q {
    font-size: 20px;
    line-height: 1.45;
    margin-bottom: 1rem;
    color: var(--ink);
    font-family: 'DM Serif Display', serif;
    font-style: italic;
  }
  .reflection-sub {
    font-size: 14px;
    line-height: 1.65;
    color: var(--ink2);
    margin-bottom: 1.5rem;
  }

  .quote-bar {
    padding: 1rem 1.125rem;
    background: var(--p-light);
    border-radius: 10px;
    font-size: 13px;
    line-height: 1.65;
    color: var(--p);
    font-style: italic;
  }

  textarea, input[type="text"], input[type="email"] {
    width: 100%;
    border: none;
    border-bottom: 1px solid var(--border);
    background: transparent;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: var(--ink);
    padding: 6px 0;
    resize: none;
    outline: none;
    line-height: 1.5;
  }
  textarea::placeholder, input::placeholder { color: var(--ink3); }
  .field-label {
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink3);
    margin-bottom: 0.4rem;
    display: block;
  }
  .field-group { margin-bottom: 1.25rem; }

  .commit-box {
    background: var(--surface);
    border-radius: 10px;
    padding: 1rem 1.125rem;
    margin-top: 1.25rem;
  }
  .commit-title {
    font-size: 18px;
    letter-spacing: 0.1em;
    font-weight: 400;
    margin-bottom: 0.25rem;
  }
  .commit-steps {
    font-size: 11px;
    color: var(--ink3);
    line-height: 1.9;
    letter-spacing: 0.02em;
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 1.5rem;
    gap: 12px;
  }
  .nav button {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    padding: 9px 22px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: transparent;
    color: var(--ink);
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
    letter-spacing: 0.02em;
  }
  .nav button:hover { background: var(--surface); }
  .nav button:disabled { opacity: 0.3; cursor: default; pointer-events: none; }
  .nav button.primary { background: var(--ink); color: #fff; border-color: var(--ink); }
  .nav button.primary:hover { opacity: 0.88; }

  .dots { display: flex; gap: 7px; align-items: center; }
  .dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--border);
    transition: background 0.2s, transform 0.2s;
    cursor: pointer;
  }
  .dot.active { background: var(--ink); transform: scale(1.3); }

  .pilot-banner {
    background: var(--teal-light);
    border: 1px solid rgba(15,110,86,0.15);
    border-radius: 10px;
    padding: 0.875rem 1rem;
    font-size: 12px;
    color: var(--teal);
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }
  .pilot-banner strong { font-weight: 500; display: block; margin-bottom: 2px; }

  /* Submit button */
  .submit-btn {
    width: 100%;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    padding: 11px;
    border: 1px solid var(--teal);
    border-radius: 8px;
    background: transparent;
    color: var(--teal);
    cursor: pointer;
    margin-top: 1rem;
    letter-spacing: 0.02em;
    transition: background 0.15s;
  }
  .submit-btn:hover { background: var(--teal-light); }
  .submit-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  /* Success state */
  .success-msg {
    display: none;
    background: var(--teal-light);
    border: 1px solid rgba(15,110,86,0.2);
    border-radius: 10px;
    padding: 1rem 1.125rem;
    margin-top: 1rem;
    font-size: 13px;
    color: var(--teal);
    line-height: 1.6;
    text-align: center;
  }
  .success-msg.visible { display: block; }

  /* Error state */
  .error-msg {
    display: none;
    background: var(--coral-light);
    border: 1px solid rgba(153,60,29,0.15);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    margin-top: 0.75rem;
    font-size: 12px;
    color: var(--coral);
    line-height: 1.6;
  }
  .error-msg.visible { display: block; }

  .accent-line {
    width: 28px;
    height: 2.5px;
    border-radius: 2px;
    margin-bottom: 1rem;
  }

  /* Print styles */
  @media print {
    body { background: white; padding: 0; }
    .nav, .top-label, .submit-btn, .pilot-banner { display: none !important; }
    .page { display: flex !important; box-shadow: none; border: none; page-break-after: always; min-height: 100vh; }
  }
</style>
</head>
<body>

<div class="top-label">Violence Ends With Us · PAUSE Toolkit</div>

<div class="flipbook">

  <!-- Page 0: Cover -->
  <div id="page-0" class="page active">
    <div>
      <div class="page-label">A tool for positive discipline</div>
      <div class="cover-title">PAUSE</div>
      <div class="cover-sub">Positive Alternatives to Unsafe &amp; Severe Enforcement</div>
      <div class="cover-hook">What will you do in the next 5 seconds?</div>
      <div class="cover-desc">
        This flipbook walks you through a simple 5-step framework for responding to children with care — not fear.<br><br>
        Use it alone, in a workshop, or with a group. Keep it close for the moments that matter.
      </div>
    </div>
    <div style="font-size:12px;color:var(--ink3);margin-top:1.5rem;">
      9 pages · Pilot edition · Asia-Pacific
    </div>
  </div>

  <!-- Page 1: Safeguarding Commitment -->
  <div id="page-1" class="page">
    <div>
      <div class="page-label">Before we begin</div>
      <div class="progress-bar"><div class="progress-fill" style="width:11%"></div></div>
      <div style="font-family:'DM Serif Display',serif;font-size:22px;margin-bottom:1rem;color:var(--ink);">Our commitment to safety</div>
      <div style="font-size:13px;line-height:1.75;color:var(--ink2);margin-bottom:1.25rem;">
        PAUSE is a safe space. Everything shared in this session stays within this group. No one will be judged for what they share or what they have experienced.
      </div>

      <div class="scenario-box" style="margin-bottom:1rem;">
        <div class="scenario-label">If something difficult comes up</div>
        If anything shared during this session raises a concern about a child's safety — including your own child — your facilitator is here to help connect you with the right support. You will never be alone in that moment.
      </div>

      <div class="scenario-box" style="margin-bottom:1rem;background:var(--p-light);">
        <div class="scenario-label" style="color:var(--p);">Child protection hotline</div>
        <div style="color:var(--p);font-size:13px;line-height:1.65;">
          Philippines: <strong>1343</strong> — DSWD Action Center<br>
          Vietnam: <strong>111</strong> — National Child Protection Hotline<br>
          Cambodia: <strong>1280</strong> — Child Helpline
        </div>
      </div>

      <div style="font-size:12px;line-height:1.7;color:var(--ink3);">
        This toolkit follows the Save the Children Child Safeguarding Policy. Every facilitator has been briefed on do-no-harm principles and in-country referral pathways before running this session.
      </div>
    </div>
    <div style="font-size:11px;color:var(--ink3);margin-top:1rem;line-height:1.6;">
      Violence Ends With Us · Asia-Pacific 2026
    </div>
  </div>

  <!-- Page 2: Reflection opener -->
  <div id="page-1" class="page">
    <div>
      <div class="page-label">Before we start</div>
      <div class="progress-bar"><div class="progress-fill" style="width:11%"></div></div>
      <div class="reflection-q">"Think about how you were disciplined as a child."</div>
      <div class="reflection-sub">What happened when you made a mistake? How did it feel? Do you still carry that feeling today?</div>
      <div class="quote-bar">Most of us were never taught another way. PAUSE gives you one.</div>
    </div>
    <div class="scenario-box" style="margin-top:1.25rem;">
      <div class="scenario-label">As you read each step, think of a real moment.</div>
      A time your child made a mistake. A time you reacted in a way you wish you hadn't. That moment is where PAUSE begins.
    </div>
  </div>

  <!-- Page 2: P -->
  <div id="page-2" class="page">
    <div>
      <div class="page-label">Step 1 of 5</div>
      <div class="progress-bar"><div class="progress-fill" style="width:25%"></div></div>
      <div class="accent-line" style="background:var(--p);"></div>
      <div class="step-letter" style="color:var(--p);">P</div>
      <div class="step-word">Pause</div>
      <div class="step-action">Stop before you react. Take one breath. Give yourself 5 seconds before you do or say anything.</div>
      <div class="step-why">The urge to react comes from the body, not the mind. One breath creates enough space to choose what happens next.</div>
    </div>
    <div class="scenario-box">
      <div class="scenario-label">In the moment</div>
      Your child broke something after you told them not to. You feel the anger rise. Before anything else — breathe. Just breathe.
    </div>
  </div>

  <!-- Page 3: A -->
  <div id="page-3" class="page">
    <div>
      <div class="page-label">Step 2 of 5</div>
      <div class="progress-bar"><div class="progress-fill" style="width:40%"></div></div>
      <div class="accent-line" style="background:var(--teal);"></div>
      <div class="step-letter" style="color:var(--teal);">A</div>
      <div class="step-word">Ask</div>
      <div class="step-action">Ask the child what happened. Let them speak first. Listen without interrupting.</div>
      <div class="step-why">Children often act out for reasons adults don't see. Asking before assuming shows respect — and gets you closer to the truth.</div>
    </div>
    <div class="scenario-box">
      <div class="scenario-label">In the moment</div>
      "What happened?" — said calmly, not as an accusation. Wait for the answer even if it takes a moment to come.
    </div>
  </div>

  <!-- Page 4: U -->
  <div id="page-4" class="page">
    <div>
      <div class="page-label">Step 3 of 5</div>
      <div class="progress-bar"><div class="progress-fill" style="width:55%"></div></div>
      <div class="accent-line" style="background:var(--amber);"></div>
      <div class="step-letter" style="color:var(--amber);">U</div>
      <div class="step-word">Understand</div>
      <div class="step-action">Consider why they did it. Were they scared? Confused? Bored? Testing limits? Still learning?</div>
      <div class="step-why">Behavior is communication. What looks like defiance is often a need the child doesn't know how to express yet.</div>
    </div>
    <div class="scenario-box">
      <div class="scenario-label">In the moment</div>
      Ask yourself: "What was going on for them?" Not to excuse the behavior — but to understand it before you respond.
    </div>
  </div>

  <!-- Page 5: S -->
  <div id="page-5" class="page">
    <div>
      <div class="page-label">Step 4 of 5</div>
      <div class="progress-bar"><div class="progress-fill" style="width:70%"></div></div>
      <div class="accent-line" style="background:var(--coral);"></div>
      <div class="step-letter" style="color:var(--coral);">S</div>
      <div class="step-word">Support</div>
      <div class="step-action">Respond to the real need behind the behavior — not just the behavior itself. Guide, don't punish.</div>
      <div class="step-why">Children learn better through guidance than fear. A child who is supported feels safe enough to do better next time.</div>
    </div>
    <div class="scenario-box">
      <div class="scenario-label">In the moment</div>
      What does your child actually need right now? Calm redirection. A clear boundary, explained. Your presence, not your anger.
    </div>
  </div>

  <!-- Page 6: E -->
  <div id="page-6" class="page">
    <div>
      <div class="page-label">Step 5 of 5</div>
      <div class="progress-bar"><div class="progress-fill" style="width:85%"></div></div>
      <div class="accent-line" style="background:var(--green);"></div>
      <div class="step-letter" style="color:var(--green);">E</div>
      <div class="step-word">Encourage</div>
      <div class="step-action">End with something that builds trust, not fear. Let them know the mistake doesn't change how much you love them.</div>
      <div class="step-why">Children who feel loved after a mistake are more likely to be honest, try again, and trust the adults in their lives.</div>
    </div>
    <div class="scenario-box">
      <div class="scenario-label">In the moment</div>
      "I know you can do better. I'm here." That's it. That's enough.
    </div>
  </div>

  <!-- Page 7: Commitment + Formspree Form -->
  <div id="page-7" class="page">
    <div>
      <div class="page-label">Your commitment</div>
      <div class="progress-bar"><div class="progress-fill" style="width:100%"></div></div>
      <div class="reflection-q">Is that the memory you want your child to have of you?</div>
      <div class="reflection-sub">You don't have to be perfect. You just have to pause — one moment at a time.</div>



      <!-- Formspree Form -->
      <form id="pause-form">

        <div class="field-group">
          <label class="field-label" for="participant_name">Your name (optional)</label>
          <input type="text" id="participant_name" name="participant_name" placeholder="First name or leave blank" />
        </div>

        <div class="field-group">
          <label class="field-label" for="learned">One thing I learned today</label>
          <textarea id="learned" name="learned" rows="2" placeholder="Write freely..." required></textarea>
          <span data-fs-error="learned" style="font-size:11px;color:var(--coral);"></span>
        </div>

        <div class="field-group">
          <label class="field-label" for="support_person">One person I can call when I'm struggling to pause</label>
          <input type="text" id="support_person" name="support_person" placeholder="Their name" required />
          <span data-fs-error="support_person" style="font-size:11px;color:var(--coral);"></span>
        </div>

        <div class="field-group">
          <label class="field-label" for="commit_moment">I commit to trying PAUSE when...</label>
          <textarea id="commit_moment" name="commit_moment" rows="2" placeholder="Describe your moment..." required></textarea>
          <span data-fs-error="commit_moment" style="font-size:11px;color:var(--coral);"></span>
        </div>

        <!-- Hidden fields for facilitator tracking -->
        <input type="hidden" name="session_location" value="Valenzuela City, Philippines" />
        <input type="hidden" name="toolkit_version" value="Pilot Edition · Asia-Pacific 2026" />

        <div class="commit-box">
          <div class="commit-title">P · A · U · S · E</div>
          <div class="commit-steps">
            Pause · Ask · Understand · Support · Encourage<br>
            Violence ends with us.
          </div>
        </div>

        <!-- Error message -->
        <div class="error-msg" id="form-error">
          Something went wrong. Please try again or check your connection.
        </div>

        <!-- Success message (shown after submit) -->
        <div class="success-msg" id="form-success">
          ✓ Your commitment has been saved. Thank you for choosing to pause. Violence ends with us.
        </div>

        <button type="submit" class="submit-btn" id="submit-btn">Save my commitment</button>

      </form>
    </div>
  </div>



  <!-- Navigation -->
  <div class="nav">
    <button id="prev-btn" onclick="changePage(-1)" disabled>Back</button>
    <div class="dots" id="dots"></div>
    <button id="next-btn" class="primary" onclick="changePage(1)">Next</button>
  </div>

</div>

<script>
  // ── Flipbook navigation ──────────────────────────────────────────
  let current = 0;
  const total = 9;

  const dotsEl = document.getElementById('dots');
  for (let i = 0; i < total; i++) {
    const d = document.createElement('div');
    d.className = 'dot' + (i === 0 ? ' active' : '');
    d.onclick = () => goTo(i);
    dotsEl.appendChild(d);
  }

  function goTo(n) {
    document.getElementById('page-' + current).classList.remove('active');
    document.querySelectorAll('.dot')[current].classList.remove('active');
    current = n;
    document.getElementById('page-' + current).classList.add('active');
    document.querySelectorAll('.dot')[current].classList.add('active');
    document.getElementById('prev-btn').disabled = current === 0;
    const nextBtn = document.getElementById('next-btn');
    nextBtn.disabled = current === total - 1;
    nextBtn.textContent = current === total - 2 ? 'Finish' : 'Next';
  }

  function changePage(dir) { goTo(current + dir); }

  // ── Formspree Ajax submission ────────────────────────────────────
  const form = document.getElementById('pause-form');
  const submitBtn = document.getElementById('submit-btn');
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');

  form.addEventListener('submit', async function (e) {
    e.preventDefault();

    // Reset messages
    successMsg.classList.remove('visible');
    errorMsg.classList.remove('visible');

    // Disable button while submitting
    submitBtn.disabled = true;
    submitBtn.textContent = 'Saving...';

    const data = new FormData(form);

    try {
      const response = await fetch('https://formspree.io/f/mzdwqabv', {
        method: 'POST',
        body: data,
        headers: { 'Accept': 'application/json' }
      });

      if (response.ok) {
        // Show success
        successMsg.classList.add('visible');
        submitBtn.style.display = 'none';
        // Clear form fields
        form.querySelectorAll('textarea, input[type="text"]').forEach(el => el.value = '');
      } else {
        // Show error
        errorMsg.classList.add('visible');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Save my commitment';
      }
    } catch (err) {
      // Network error
      errorMsg.classList.add('visible');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Save my commitment';
    }
  });
</script>
</body>
</html>
